# =====================================================
#  MADHAVI ENTERPRISES — ENVIRONMENT CONFIGURATION
#  Fill in your actual API keys below
# =====================================================

# ===== JWT SECRET (change this to a strong random string) =====
JWT_SECRET=your_jwt_secret_here

# ===== ADMIN CREDENTIALS =====
ADMIN_EMAIL=admin@madhavienterprise.com
ADMIN_PASSWORD=your_admin_password_here

# ===== OMNIDIMENSION AI VOICE =====
OMNI_API_KEY=your_omni_api_key_here
OMNI_AGENT_ID=your_omni_agent_id_here

# ===== ULTRAMSG WHATSAPP =====
ULTRAMSG_INSTANCE_ID=your_ultramsg_instance_id_here
ULTRAMSG_TOKEN=your_ultramsg_token_here

# ===== CLOUDINARY (Image Storage & CDN) =====
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ===== GEMINI =====
GEMINI_API_KEY=your_gemini_api_key_here
